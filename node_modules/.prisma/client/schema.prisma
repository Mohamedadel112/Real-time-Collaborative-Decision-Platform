// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UserRole {
  GUEST
  USER
  TRUSTED_USER
  EXPERT
  ADMIN
}

enum DecisionStatus {
  OPEN
  CLOSED
  VALIDATED
  INVALID
}

enum VoteValidationStatus {
  PENDING
  CORRECT
  INCORRECT
}

// ─── Models ────────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  username         String   @unique
  passwordHash     String
  role             UserRole @default(GUEST)
  isEmailVerified  Boolean  @default(false)
  isInvitedByAdmin Boolean  @default(false)
  reputation       Float    @default(0)
  votesCount       Int      @default(0)
  correctVotes     Int      @default(0)
  domainExpertise  String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  ownedRooms      Room[]           @relation("RoomOwner")
  roomMemberships RoomMember[]
  votes           Vote[]
  sentInvites     RoomInvite[]     @relation("InviteSender")
  receivedInvites RoomInvite[]     @relation("InviteReceiver")
  decisionReviews DecisionReview[]
  auditLogs       AuditLog[]

  @@index([email])
  @@index([role])
}

model Room {
  id          String   @id @default(uuid())
  name        String
  description String?
  topic       String?
  isPrivate   Boolean  @default(false)
  ownerId     String
  maxMembers  Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner     User         @relation("RoomOwner", fields: [ownerId], references: [id])
  members   RoomMember[]
  decisions Decision[]
  invites   RoomInvite[]

  @@index([ownerId])
}

model RoomMember {
  id       String   @id @default(uuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())

  // Relations
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model RoomInvite {
  id         String   @id @default(uuid())
  roomId     String
  senderId   String
  receiverId String
  accepted   Boolean? // null = pending, true = accepted, false = declined
  createdAt  DateTime @default(now())

  room     Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender   User @relation("InviteSender", fields: [senderId], references: [id])
  receiver User @relation("InviteReceiver", fields: [receiverId], references: [id])

  @@unique([roomId, senderId, receiverId])
}

model Decision {
  id            String         @id @default(uuid())
  roomId        String
  title         String
  description   String?
  domain        String?
  status        DecisionStatus @default(OPEN)
  confidence    Float          @default(0)
  winningOption String?
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  room    Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  options DecisionOption[]
  votes   Vote[]
  reviews DecisionReview[]

  @@index([roomId])
  @@index([status])
}

model DecisionOption {
  id          String   @id @default(uuid())
  decisionId  String
  label       String
  description String?
  totalWeight Float    @default(0)
  votesCount  Int      @default(0)
  createdAt   DateTime @default(now())

  // Relations
  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  votes    Vote[]

  @@index([decisionId])
}

model Vote {
  id         String               @id @default(uuid())
  decisionId String
  optionId   String
  userId     String
  weight     Float                @default(1)
  validation VoteValidationStatus @default(PENDING)
  createdAt  DateTime             @default(now())

  // Relations
  decision Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  option   DecisionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([decisionId, userId]) // One vote per user per decision
  @@index([decisionId])
  @@index([userId])
}

model DecisionReview {
  id         String   @id @default(uuid())
  decisionId String
  userId     String
  isCorrect  Boolean
  comment    String?
  createdAt  DateTime @default(now())

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([decisionId, userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
}
